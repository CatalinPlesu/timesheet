{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.OpenTelemetry" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "Polly": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/timesheet-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "http://localhost:5080/api/default/v1/logs",
          "protocol": "HttpProtobuf",
          "headers": {
            "Authorization": "Basic cm9vdEBleGFtcGxlLmNvbTpDb21wbGV4cGFzcyMxMjM="
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "CHANGE-ME-IN-PRODUCTION-USE-A-SECURE-RANDOM-KEY-AT-LEAST-32-CHARACTERS-LONG",
    "Issuer": "TimeSheet.API",
    "Audience": "TimeSheet.Web",
    "ExpirationMinutes": 10080,
    "RefreshGraceDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:8080",
      "https://timesheet.catalinplesu.xyz"
    ]
  },
  "FrontendUrl": "https://timesheet.catalinplesu.xyz",
  "OpenTelemetry": {
    "ServiceName": "timesheet-api",
    "Endpoint": "http://localhost:5080/api/default/v1/traces",
    "Headers": "Authorization=Basic cm9vdEBleGFtcGxlLmNvbTpDb21wbGV4cGFzcyMxMjM="
  }
}
