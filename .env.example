# Docker image configuration
# GitHub username or org that owns the GHCR packages
REPO_OWNER=your-github-username
IMAGE_TAG=latest

# Telegram bot token (required)
BOT_TOKEN=your-telegram-bot-token-here

# JWT settings (required)
# Generate a secure random key: openssl rand -base64 32
JWT_SECRET_KEY=CHANGE-ME-USE-A-SECURE-RANDOM-KEY-AT-LEAST-32-CHARACTERS-LONG
JWT_ISSUER=TimeSheet.API
JWT_AUDIENCE=TimeSheet.Web
JWT_EXPIRATION_MINUTES=60

# Port mappings (host ports exposed by docker compose)
API_PORT=5000
FRONTEND_PORT=3000

# Frontend URL (used by API for CORS and by bot for login links)
FRONTEND_EXTERNAL_URL=http://localhost:3000

# Employer API (set to empty string if not used)
EMPLOYER_API_BASE_URL=

# Worker check intervals (TimeSpan format: hh:mm:ss)
AUTO_SHUTDOWN_CHECK_INTERVAL=00:03:00
FORGOT_SHUTDOWN_CHECK_INTERVAL=00:03:00
LUNCH_REMINDER_CHECK_INTERVAL=00:03:00
WORK_HOURS_ALERT_CHECK_INTERVAL=00:03:00
